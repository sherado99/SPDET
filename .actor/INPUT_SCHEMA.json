{
  "title": "Stech Email Tone Improver (Batch)",
  "description": "Rewrite multiple emails to be warm, honest, and personal using Stech AI. Upload a CSV file or provide an array of emails.",
  "type": "object",
  "schemaVersion": 1,
  "properties": {
    "csvFile": {
      "title": "CSV File",
      "type": "string",
      "description": "Upload a CSV file with columns: originalEmail (required), targetTone (optional), additionalInstructions (optional).",
      "editor": "fileupload"
    },
    "emails": {
      "title": "Emails Array (Alternative)",
      "type": "array",
      "description": "If you prefer JSON, provide an array of email objects.",
      "editor": "json",
      "prefill": [
        {
          "originalEmail": "Dear Sir, your application has been rejected.",
          "targetTone": "empathetic",
          "additionalInstructions": "Keep it under 30 words"
        }
      ],
      "items": {
        "type": "object",
        "properties": {
          "originalEmail": { "type": "string", "title": "Original Email" },
          "targetTone": {
            "type": "string",
            "title": "Target Tone",
            "default": "warm and honest",
            "enum": ["warm and honest", "friendly", "empathetic", "encouraging", "professional-warm"]
          },
          "additionalInstructions": { "type": "string", "title": "Additional Instructions", "editor": "textarea" }
        },
        "required": ["originalEmail"]
      }
    },
    "defaultTone": {
      "title": "Default Tone",
      "type": "string",
      "default": "warm and honest",
      "enum": ["warm and honest", "friendly", "empathetic", "encouraging", "professional-warm"]
    },
    "maxConcurrency": {
      "title": "Max Concurrency",
      "type": "integer",
      "minimum": 1,
      "maximum": 20,
      "default": 5
    },
    "timeout": {
      "title": "Timeout (seconds)",
      "type": "integer",
      "minimum": 10,
      "maximum": 300,
      "default": 60
    }
  }
}
