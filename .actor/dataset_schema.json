{
    "actorSpecification": 1,
    "fields": {
        "$schema": "http://json-schema.org/draft-07/schema#",
        "type": "object",
        "properties": {
            "originalEmail": {
                "type": "string",
                "title": "Original Email",
                "description": "The original cold email provided by the user.",
                "example": "Dear Sir, your application has been rejected."
            },
            "improvedEmail": {
                "type": "string",
                "title": "Improved Email",
                "description": "The email rewritten by Stech AI with a warmer, more honest tone.",
                "example": "Hi, thank you for applying. Unfortunately we couldn't move forward this time, but we appreciate your effort."
            },
            "toneUsed": {
                "type": "string",
                "title": "Tone Used",
                "description": "The tone applied to the email (e.g., warm, empathetic, friendly).",
                "example": "empathetic"
            },
            "status": {
                "type": "string",
                "title": "Status",
                "description": "The success or failure status of the processing.",
                "enum": ["success", "error"],
                "example": "success"
            },
            "timestamp": {
                "type": "string",
                "title": "Timestamp",
                "description": "The processing timestamp in ISO 8601 format.",
                "example": "2026-04-21T10:30:00.000Z"
            }
        },
        "required": ["originalEmail", "improvedEmail", "status"]
    },
    "views": {
        "overview": {
            "title": "SETI Email Rewrite Results",
            "transformation": {
                "fields": [
                    "originalEmail",
                    "improvedEmail",
                    "toneUsed",
                    "status",
                    "timestamp"
                ]
            },
            "display": {
                "component": "table",
                "properties": {
                    "originalEmail": {
                        "label": "Original Email",
                        "format": "text"
                    },
                    "improvedEmail": {
                        "label": "Improved Email",
                        "format": "text"
                    },
                    "toneUsed": {
                        "label": "Tone",
                        "format": "text"
                    },
                    "status": {
                        "label": "Status",
                        "format": "text"
                    },
                    "timestamp": {
                        "label": "Time",
                        "format": "text"
                    }
                }
            }
        }
    }
}
