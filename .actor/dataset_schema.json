{
  "datasetSchemaVersion": 1,
  "title": "SETI Email Rewrite Result",
  "properties": {
    "emailResult": {
      "type": "object",
      "title": "Email Result",
      "template": "{{originalEmail}} → {{improvedEmail}} ({{toneUsed}})",
      "properties": {
        "originalEmail": {
          "type": "string",
          "title": "Original Email",
          "template": "{{originalEmail}}"
        },
        "improvedEmail": {
          "type": "string",
          "title": "Improved Email",
          "template": "{{improvedEmail}}"
        },
        "toneUsed": {
          "type": "string",
          "title": "Tone Used",
          "template": "{{toneUsed}}"
        },
        "status": {
          "type": "string",
          "title": "Status",
          "template": "{{status}}"
        },
        "timestamp": {
          "type": "string",
          "title": "Timestamp",
          "template": "{{timestamp}}"
        }
      },
      "required": ["originalEmail", "improvedEmail", "status"]
    }
  },
  "required": ["emailResult"]
}