{
  "actorSpecification": 1,
  "fields": {
    "$schema": "http://json-schema.org/draft-07/schema#",
    "type": "object",
    "properties": {
      "originalEmail": {
        "type": "string",
        "title": "Original Email",
        "description": "The original cold email provided by the user.",
        "example": "Dear Sir, your application has been rejected."
      },
      "improvedEmail": {
        "type": "string",
        "title": "Improved Email",
        "description": "The email rewritten by Stech AI with a warmer, more honest tone.",
        "example": "Hi, thank you for applying. Unfortunately we couldn't move forward this time, but we appreciate your effort."
      },
      "status": {
        "type": "string",
        "title": "Status",
        "description": "The success or failure status of the processing.",
        "enum": ["success", "error"],
        "example": "success"
      },
      "timestamp": {
        "type": "string",
        "title": "Timestamp",
        "description": "The processing timestamp in ISO 8601 format.",
        "example": "2026-04-21T10:30:00.000Z"
      },
      "auditHash": {
        "type": "string",
        "title": "Audit Hash",
        "description": "SHA-256 hash of originalEmail + improvedEmail + timestamp for audit trail and EU AI Act compliance.",
        "example": "a3f2b8c9d1e4f5a6b7c8d9e0f1a2b3c4d5e6f7a8b9c0d1e2f3a4b5c6d7e8f9"
      },
      "download_docx": {
        "type": "string",
        "title": "Download DOCX",
        "description": "URL to download the improved email as a Microsoft Word (.docx) file.",
        "example": "https://api.apify.com/v2/key-value-stores/STORE_ID/records/email_1_a3f2b8c9.docx"
      },
      "download_pdf": {
        "type": "string",
        "title": "Download PDF",
        "description": "URL to download the improved email as a PDF file.",
        "example": "https://api.apify.com/v2/key-value-stores/STORE_ID/records/email_1_a3f2b8c9.pdf"
      },
      "originalSubject": {
        "type": "string",
        "title": "Original Subject",
        "description": "Original email subject line.",
        "example": "Application Status"
      },
      "recipientName": {
        "type": "string",
        "title": "Recipient Name",
        "description": "Name of the recipient.",
        "example": "John"
      },
      "senderName": {
        "type": "string",
        "title": "Sender Name",
        "description": "Name of the sender.",
        "example": "HR Team"
      },
      "recipientEmail": {
        "type": "string",
        "title": "Recipient Email",
        "description": "Email address of the recipient.",
        "example": "john@example.com"
      }
    },
    "required": ["originalEmail", "improvedEmail", "status", "auditHash", "download_docx", "download_pdf"]
  },
  "views": {
    "overview": {
      "title": "SPDET Email Rewrite Results",
      "transformation": {
        "fields": [
          "originalEmail",
          "improvedEmail",
          "status",
          "timestamp",
          "auditHash",
          "download_docx",
          "download_pdf",
          "originalSubject",
          "recipientName",
          "senderName",
          "recipientEmail"
        ]
      },
      "display": {
        "component": "table",
        "properties": {
          "originalEmail": { "label": "Original Email", "format": "text" },
          "improvedEmail": { "label": "Improved Email", "format": "text" },
          "status": { "label": "Status", "format": "text" },
          "timestamp": { "label": "Time", "format": "text" },
          "auditHash": { "label": "Audit Hash", "format": "text" },
          "download_docx": { "label": "Download DOCX", "format": "text" },
          "download_pdf": { "label": "Download PDF", "format": "text" },
          "originalSubject": { "label": "Original Subject", "format": "text" },
          "recipientName": { "label": "Recipient", "format": "text" },
          "senderName": { "label": "Sender", "format": "text" },
          "recipientEmail": { "label": "Recipient Email", "format": "text" }
        }
      }
    }
  }
}